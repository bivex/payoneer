# Payoneer Privacy Policy - Section 3: How and Why We Use Personal Data
# Last updated: May 2026

# --- Service Provision ---

scope UseServiceProvision =
  output usedForAccountOpening : Boolean
  output usedForKYCVerification : Boolean
  output usedForTransactionProcessing : Boolean
  output usedForPaymentProcessing : Boolean
  output usedForCustomerSupport : Boolean

  definition usedForAccountOpening equals true
  definition usedForKYCVerification equals true
  definition usedForTransactionProcessing equals true
  definition usedForPaymentProcessing equals true
  definition usedForCustomerSupport equals true

# --- Security and Fraud Prevention ---

scope UseSecurityFraudPrevention =
  output usedForFraudPrevention : Boolean
  output usedForRiskAssessment : Boolean
  output usedForSecurityPurposes : Boolean
  output usedForAntiMoneyLaundering : Boolean
  output usedForSanctionsScreening : Boolean
  output usedForIdentityVerification : Boolean

  definition usedForFraudPrevention equals true
  definition usedForRiskAssessment equals true
  definition usedForSecurityPurposes equals true
  definition usedForAntiMoneyLaundering equals true
  definition usedForSanctionsScreening equals true
  definition usedForIdentityVerification equals true

