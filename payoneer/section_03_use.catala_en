  definition usedForLegalCompliance equals true
  definition usedForRegulatoryReporting equals true
  definition usedForTaxReporting equals true
  definition usedForLawEnforcementRequests equals true
  definition usedForCourtOrders equals true

# --- Marketing and Communications ---

scope UseMarketing =
  input hasMarketingConsent : Boolean
  output usedForMarketingCommunications : Boolean
  output usedForProductUpdates : Boolean
  output usedForPromotionalOffers : Boolean
