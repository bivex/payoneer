  output canOptOutAtAnyTime : Boolean

  definition usedForMarketingCommunications equals hasMarketingConsent
  definition usedForProductUpdates equals true
  definition usedForPromotionalOffers equals hasMarketingConsent
  definition marketingRequiresConsent equals true
  definition canOptOutAtAnyTime equals true

