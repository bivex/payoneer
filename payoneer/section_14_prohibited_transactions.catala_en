# --- India Restricted Transactions ---

scope ProhibitedIndiaRestricted =
  input transactionInvolvesIndia : Boolean
  output indiaForeignTradePolicyApplies : Boolean
  output prohibitedItemsPerFTP : Boolean
  output restrictedItemsPerFTP : Boolean
  output STEItemsPerFTP : Boolean
  output scometItemsRestricted : Boolean
  output specialChemicalsOrganismsMaterials : Boolean
  output scometAppliesToImportAndExport : Boolean

  definition indiaForeignTradePolicyApplies equals transactionInvolvesIndia
  definition prohibitedItemsPerFTP equals transactionInvolvesIndia
  definition restrictedItemsPerFTP equals transactionInvolvesIndia
  definition STEItemsPerFTP equals transactionInvolvesIndia
  definition scometItemsRestricted equals transactionInvolvesIndia
  definition specialChemicalsOrganismsMaterials equals transactionInvolvesIndia
  definition scometAppliesToImportAndExport equals transactionInvolvesIndia

# --- Pre-Approval Exception ---

scope ProhibitedPreApproval =
  output payoneerMayPreApproveSomeCategories : Boolean
  output subjectToReviewAndExamination : Boolean
  output subjectToSoleDiscretion : Boolean
  output lawViolationsNeverSupported : Boolean

  definition payoneerMayPreApproveSomeCategories equals true
  definition subjectToReviewAndExamination equals true
  definition subjectToSoleDiscretion equals true
  definition lawViolationsNeverSupported equals true

# --- Transaction Prohibition Check ---

scope ProhibitedTransactionCheck =
  input isAdultService : Boolean
  input involvesAnimalsWildlife : Boolean
  input isProhibitedLegalService : Boolean
  input isProhibitedFinancialService : Boolean
  input involvesFirearmsExplosives : Boolean
  input isGambling : Boolean
  input isHighValueItemWithoutCustody : Boolean
  input isIllegalProduct : Boolean
  input involvesMarijuanaCannabis : Boolean
  input isNonBusinessUse : Boolean
  input involvesNonFiatCurrency : Boolean
  input involvesCounterfeitCopyright : Boolean
  input involvesGovernmentMilitary : Boolean
  input isCreditIdentityProtection : Boolean
  input isProhibitedPharmaceutical : Boolean
  input isUnfairPredatoryDeceptive : Boolean
  input involvesIPInfringement : Boolean
  input involvesTobaccoAlcohol : Boolean
  input involvesRealEstate : Boolean
  input involvesIndiaRestricted : Boolean
  input hasPreApproval : Boolean
  output transactionProhibited : Boolean

  definition transactionProhibited equals
    (isAdultService or
     involvesAnimalsWildlife or
     isProhibitedLegalService or
     isProhibitedFinancialService or
     involvesFirearmsExplosives or
     isGambling or
     isHighValueItemWithoutCustody or
     isIllegalProduct or
     involvesMarijuanaCannabis or
     isNonBusinessUse or
     involvesNonFiatCurrency or
     involvesCounterfeitCopyright or
     involvesGovernmentMilitary or
     isCreditIdentityProtection or
     isProhibitedPharmaceutical or
     isUnfairPredatoryDeceptive or
     involvesIPInfringement or
     involvesTobaccoAlcohol or
     involvesRealEstate or
     involvesIndiaRestricted) and
    not hasPreApproval
