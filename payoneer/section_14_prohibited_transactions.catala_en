# Payoneer Prohibited Transaction List
# Last updated: May 2026
# Source: https://www.payoneer.com/legal/prohibited-transactions/

# --- General Eligibility ---

scope ProhibitedTransactionEligibility =
  output servicesSubjectToEligibilityRequirements : Boolean
  output dependsOnLineOfBusiness : Boolean
  output dependsOnCountryOfResidency : Boolean
  output dependsOnAMLRregulations : Boolean
  output dependsOnPayoneerRiskPolicies : Boolean
  output payoneerHasSoleDiscretion : Boolean

  definition servicesSubjectToEligibilityRequirements equals true
  definition dependsOnLineOfBusiness equals true
  definition dependsOnCountryOfResidency equals true
  definition dependsOnAMLRregulations equals true
  definition dependsOnPayoneerRiskPolicies equals true
  definition payoneerHasSoleDiscretion equals true

