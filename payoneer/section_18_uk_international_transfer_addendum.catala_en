  output importerDetailsPerAgreement : Boolean

  definition importerIsSupplier equals true
  definition importerDetailsPerAgreement equals true

scope UKTransferAddendumContacts =
  output exporterDPOName : Boolean
  output exporterDPOEmail : Boolean
