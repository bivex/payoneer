  output exporterRegistrationNumber : Boolean

  definition exporterLegalName equals true
  definition exporterTradingName equals true
  definition exporterAddress equals true
  definition exporterRegistrationNumber equals true

scope UKTransferAddendumExporterDetails =
  output fullLegalName : Boolean
  output mainAddress : Boolean
