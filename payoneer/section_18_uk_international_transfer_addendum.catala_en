# --- Part 2: Section 19 - Ending this Addendum ---

scope UKTransferAddendumEndingConditions =
  input partySelectedInTable4 : Boolean
  input directCostIncreaseSubstantial : Boolean
  input riskIncreaseSubstantial : Boolean
  input takenReasonableStepsToReduce : Boolean
  output mayEndAddendum : Boolean

  definition mayEndAddendum equals
    partySelectedInTable4 and
    (directCostIncreaseSubstantial or riskIncreaseSubstantial) and
    takenReasonableStepsToReduce

scope UKTransferAddendumEndingProcess =
  input entitledToEnd : Boolean
  output mustProvideWrittenNotice : Boolean
  output noticeBeforeRevisedAddendumStartDate : Boolean
  output reasonableNoticePeriod : Boolean

  definition mustProvideWrittenNotice equals entitledToEnd
  definition noticeBeforeRevisedAddendumStartDate equals entitledToEnd
  definition reasonableNoticePeriod equals entitledToEnd

