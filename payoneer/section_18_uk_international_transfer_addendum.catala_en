# Payoneer UK International Data Transfer Addendum
# Last updated: May 2026
# Source: ICO Standard Data Protection Clauses under S119A(1) DPA 2018
# Version B1.0, in force 21 March 2022

# --- Part 1: Table 1 - Parties ---

scope UKTransferAddendumStartDate =
  output addendumVersion : Boolean
  output versionIdentifier : Boolean
  output inForceDate : Boolean

  definition addendumVersion equals true
  definition versionIdentifier equals true
  definition inForceDate equals true

