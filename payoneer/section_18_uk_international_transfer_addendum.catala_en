  definition addendumEU_SCCs equals true
  definition sCCCommencementPerSection13_3 equals true
  definition appendixInformationIncluded equals true

scope UKTransferAddendumSCCReference =
  output sCCDateIsTransferCommencement : Boolean
  output sCCReferenceOptional : Boolean
  output sCCOtherIdentifierOptional : Boolean

  definition sCCDateIsTransferCommencement equals true
  definition sCCReferenceOptional equals true
  definition sCCOtherIdentifierOptional equals true

scope UKTransferAddendumModuleSelection =
  input moduleInOperation : Integer
  output module1_ControllerToController : Boolean
  output module2_ControllerToProcessor : Boolean
  output module3_ProcessorToProcessor : Boolean
  output module4_ProcessorToController : Boolean
  output dockingClause7Applies : Boolean
  output clause11Applies : Boolean
  output clause9aPriorAuth : Boolean
  output clause9aTimePeriod : Boolean
  output dataCombinedWithImporterData : Boolean

  definition module1_ControllerToController equals moduleInOperation equals 1
  definition module2_ControllerToProcessor equals moduleInOperation equals 2
  definition module3_ProcessorToProcessor equals moduleInOperation equals 3
  definition module4_ProcessorToController equals moduleInOperation equals 4
  definition dockingClause7Applies equals false
  definition clause11Applies equals false
  definition clause9aPriorAuth equals false
  definition clause9aTimePeriod equals false
  definition dataCombinedWithImporterData equals false

